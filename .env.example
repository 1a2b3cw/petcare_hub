# 数据库连接（使用 Neon 的 pooler 连接串，以 -pooler 结尾的域名）
# 格式：postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DATABASE?sslmode=require
DATABASE_URL="postgresql://neondb_owner:YOUR_PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"

# NextAuth 密钥（生产环境必须换成随机字符串）
# 生成命令：openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# 部署后改成真实域名，本地开发填 http://localhost:3000
NEXTAUTH_URL="https://your-project.vercel.app"
